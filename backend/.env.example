# Admin dashboard backend config. Copy to backend/.env and fill in.

PORT=4000

# Atlas cluster URI WITH credentials — the same cluster the WED pipeline writes
# to. Read-only usage on the dataset DB. Keep out of git (.env is gitignored).
MONGODB_URI=

# READ: which DB holds the WED pipeline ledger (releases / changes).
# wed_v0 = production; point at wed_staging to view the v1..v6 backfill ledger
# before the swap.
WED_DB=wed_v0

# WRITE: the dashboard's OWN operational collection (pipeline_runs) lives here —
# the only thing the dashboard writes. Kept separate from the dataset DB.
ADMIN_DB=admin_meta

# Ingest auth (Phase 8.2/8.3). Set once the GitHub webhook + EC2 heartbeat are wired.
GITHUB_WEBHOOK_SECRET=
HEARTBEAT_SECRET=

# Allowed CORS origin for the frontend (Next dev server default below).
CORS_ORIGIN=http://localhost:3000
